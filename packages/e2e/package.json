{
  "name": "@org/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "nx": {
    "name": "e2e"
  },
  "scripts": {
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:regression": "playwright test --grep @regression",
    "e2e:api": "playwright test --project=api",
    "e2e:ui": "playwright test --project=ui-chromium",
    "e2e:headed": "playwright test --project=ui-chromium --headed",
    "e2e:report": "playwright show-report",
    "allure:generate": "allure generate ./allure-results",
    "allure:open": "allure open ./allure-report"
  },
  "dependencies": {
    "@org/contracts": "*",
    "@faker-js/faker": "^9.4.0",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "allure": "^3.9.0",
    "allure-playwright": "^3.9.0"
  }
}
