# Copy to `.env` to override defaults locally. All values have safe defaults
# (see src/support/env.ts), so the suite runs without a .env file.

# Base URL of the web SPA under test (Playwright `baseURL` for the ui project).
BASE_URL=http://localhost:4200

# Base URL of the Hono API (used by the api project + ApiClient).
API_URL=http://localhost:3333

# Winston log verbosity: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
